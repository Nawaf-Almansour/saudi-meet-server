      participants,
      pollDataWithOption.allRespondents,
      (a, b) => a.userId === b.userId,
    ).map((p) => ({ userId: p.userId, name: p.name }));

    return {
      formattedNotRespondents: getFormatedRespondents(notRespondentsList),
      notRespondentsCount: notRespondentsList.length,
