<body>
<div class="container">
    <div class="logo">
        <img src="./assets/imgs/main-logo-light.png" alt="main-logo"/>
    </div>
    <div class="form">
        <form action="#" method="POST" id="loginForm">
            <div class="inputs-wrapper">
                <div class="item">
                    <label for="api_key" class="form-label">plugNmeet API Key</label>
                    <input
                            type="text"
